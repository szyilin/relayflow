# =============================================================================
# RelayFlow .gitignore
# 策略说明见 docs/dev/git-and-idea.md
# =============================================================================

# --- 密钥与环境（切勿提交） ---
.env
.env.*
!.env.example

# --- 操作系统 ---
.DS_Store
Thumbs.db

# --- IntelliJ IDEA ---
# 共享配置在 .idea/ 下提交；个人状态由 .idea/.gitignore 排除
*.iml
*.ipr
*.iws
out/

# --- Eclipse / VS Code（本仓库主用 IDEA，仍忽略以免误提交） ---
.classpath
.project
.settings/
.factorypath
.vscode/*
!.vscode/extensions.json

# --- Cursor：共享 rules/skills，忽略本地会话状态 ---
.cursor/*
!.cursor/rules/
!.cursor/commands/
!.cursor/skills/

# --- 其他 AI 工具本地目录 ---
.claude/
.codex/
.windsurf/
.opencode/

# --- 个人本地覆盖 ---
CLAUDE.local.md
**/*.local.md

# --- OpenSpec 废弃路径 ---
openspec/AGENTS.md
openspec/project.md

# --- Java / Maven ---
target/
*.class
*.war
*.ear
.flattened-pom.xml
hs_err_pid*
replay_pid*
# 业务 JAR/WAR 不提交；Maven Wrapper JAR 例外（见下方 !）
*.jar
!.mvn/wrapper/maven-wrapper.jar

# --- 前端 web/ ---
web/node_modules/
web/dist/
web/.vite/
web/*.tsbuildinfo
.pnpm-store/

# --- Docker / 本地运行数据 ---
data/
*.log
