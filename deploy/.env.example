# Copy to deploy/.env and adjust for local development.
# 开发：deploy/compose.yml（仅基础设施）
# 部署：deploy/compose.prod.yml（基础设施 + relayflow-server 容器）

POSTGRES_DB=relayflow
POSTGRES_USER=relayflow
POSTGRES_PASSWORD=relayflow
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 后端 API（容器映射到宿主机；前端 pnpm dev 通过 Vite 代理访问）
SERVER_PORT=8080

# Application (relayflow-server) and codegen CLI (scripts/codegen.sh)
# 本机 mvn/spring-boot:run 时使用 localhost；Docker Compose 内 server 服务用 postgres/redis/minio 主机名。
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/relayflow
SPRING_REDIS_HOST=localhost
RELAYFLOW_MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Object storage bootstrap (relayflow.storage.*)
RELAYFLOW_STORAGE_DEFAULT_PROVIDER=minio
RELAYFLOW_STORAGE_VALIDATE_ON_STARTUP=true
RELAYFLOW_STORAGE_MINIO_BUCKET=relayflow

# Tenant (V1 default: single-tenant product mode, tenant-ready data model)
RELAYFLOW_TENANT_ENABLED=false
RELAYFLOW_TENANT_DEFAULT_ID=1
RELAYFLOW_JWT_SECRET=dev-only-change-me-in-production
