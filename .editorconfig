# EditorConfig — IDEA / VS Code / Cursor 通用
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,xml,yml,yaml,properties,md,json,ts,vue}]
indent_style = space
indent_size = 2

[*.java]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[mvnw]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
